# ==============================================
# Jacaranda - Configuración del Sistema
# ==============================================

# Base de datos
DATABASE_URL=sqlite:///./jacaranda.db
ENVIRONMENT=development
ALLOW_SQLITE_IN_PRODUCTION=false
ALLOW_CREATE_ALL_FALLBACK=false

# Seguridad
SECRET_KEY=
DEBUG=false

# Usuario inicial. Si se omite ADMIN_PASSWORD, el arranque genera una clave
# temporal aleatoria en .admin_password para evitar credenciales predecibles.
ADMIN_PASSWORD=

# Datos del negocio
RAZON_SOCIAL=Jacaranda Flavors
RFC=XAXX010101000
REGIMEN_FISCAL=612
DOMICILIO_FISCAL_CP=76146
LUGAR_EXPEDICION=76146

# Zona fronteriza (IVA 8% en lugar de 16%)
ZONA_FRONTERIZA=false

# Salario mínimo (actualizar anualmente)
SALARIO_MINIMO_GENERAL=278.80
UMA_DIARIO=113.14
UMA_MENSUAL=3439.46

# CLIP - Terminal de pagos (https://developer.clip.mx/)
CLIP_API_KEY=
CLIP_API_SECRET=
CLIP_API_URL=https://api.clip.mx

# Conekta - pagos online. La llave pública verifica el header DIGEST
# de los webhooks antes de marcar pedidos como pagados.
CONEKTA_API_KEY=
CONEKTA_SANDBOX_MODE=true
CONEKTA_WEBHOOK_PUBLIC_KEY=

# WhatsApp Business. WA_APP_SECRET es obligatorio para aceptar webhooks firmados.
WA_API_TOKEN=
WA_PHONE_NUMBER_ID=
WA_VERIFY_TOKEN=jacaranda_wa_verify
WA_APP_SECRET=
WA_ALLOW_UNSIGNED_WEBHOOKS=false

# PAXSTORE Cloud API - Terminal PAX A910S (https://github.com/PAXSTORE/paxstore-openapi-java-sdk)
PAXSTORE_API_KEY=
PAXSTORE_API_SECRET=
PAXSTORE_API_URL=https://api.whatspos.com/p-market-api
PAX_TERMINAL_SN=2841093742

# BBVA API Market - Conciliación (https://www.bbvaapimarket.com/)
BBVA_CLIENT_ID=
BBVA_CLIENT_SECRET=
BBVA_API_URL=https://apis.bbva.com/mexico/v1
BBVA_TOKEN_URL=https://connect.bbva.com/token
BBVA_ACCOUNT_ID=
